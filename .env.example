# WhatsApp Cloud API (free from Meta)
WHATSAPP_TOKEN=your_permanent_access_token
WHATSAPP_PHONE_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=any_random_string_you_choose

# Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Supabase (free tier)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJxxxxx

# Your WhatsApp number (so only YOU can control the bot)
OWNER_PHONE=919876543210

# Twilio Voice (for phone calls)
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Server (Railway will set PORT automatically)
SERVER_URL=https://your-app.up.railway.app
PORT=3000
